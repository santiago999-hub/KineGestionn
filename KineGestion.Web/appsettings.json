      "ContactPhone": "",
      "ContactEmail": ""
    },
    "Templates": {
      "Email": {
        "Subject": "Recordatorio de sesión - {{SessionDateTime}}",
        "Body": "Hola {{PatientName}}, este es un recordatorio de {{ClinicName}}.\nSesión: {{SessionDateTime}}\nProfesional: {{ProfessionalName}}\nTratamiento: {{TreatmentDescription}}\n\nConfirmar asistencia: {{ConfirmUrl}}\nCancelar sesión: {{CancelUrl}}\n\n{{Signature}}"
      },
      "WhatsApp": {
        "Body": "Hola {{PatientName}}, te recordamos tu sesión de {{ClinicName}}.\nFecha: {{SessionDateTime}}\nProfesional: {{ProfessionalName}}\n\nConfirmar: {{ConfirmUrl}}\nCancelar: {{CancelUrl}}"
      }
    },
    "Email": {
      "Enabled": false,
      "SmtpHost": "",
      "SmtpPort": 587,
      "EnableSsl": true,
      "Username": "",
      "Password": "",
      "From": ""
    },
    "WhatsApp": {
      "Enabled": false,
      "ApiUrl": "",
      "ApiToken": "",
      "DefaultCountryCode": "54",
      "TimeoutSeconds": 15
    }
  },
  "Logging": {
