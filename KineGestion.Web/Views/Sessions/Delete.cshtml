@model KineGestion.Web.Models.ViewModels.SessionViewModel

@{
    ViewData["Title"] = "Eliminar Sesión";
}

<div class="kg-page-header">
    <div>
        <h2>Eliminar Sesión</h2>
        <p class="text-muted mb-0">Esta acción es permanente</p>
    </div>
    <a asp-action="Index" class="btn-kg-outline">
        <i class="bi bi-arrow-left"></i> Cancelar
    </a>
</div>

<div class="kg-form-card" style="border-top: 3px solid var(--kg-danger)">
    <div class="kg-form-header" style="background:#fff5f5">
        <div class="kg-form-header-icon" style="background:#fee2e2;color:#dc2626"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <div>
            <h4>¿Eliminar esta sesión?</h4>
            <p style="color:#dc2626">La sesión de <strong>@Model.PacienteNombre</strong> del <strong>@Model.FechaHora.ToString("dd/MM/yyyy HH:mm")</strong> será eliminada permanentemente.</p>
        </div>
    </div>
    <div class="kg-form-body">
        <div class="kg-detail-grid">
            <div class="kg-detail-item">
                <dt>Paciente</dt>
                <dd>@Model.PacienteNombre</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Profesional</dt>
                <dd>@Model.ProfesionalNombre</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Tratamiento</dt>
                <dd>@Model.TratamientoDescripcion</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Número de sesión</dt>
                <dd><span class="kg-badge kg-badge-violet">N° @Model.NroSesionEnTratamiento</span></dd>
            </div>
        </div>
    </div>
    <div class="kg-form-footer">
        <a asp-action="Index" class="btn-kg-outline"><i class="bi bi-x-lg"></i> Cancelar</a>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display:inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-kg-danger">
                <i class="bi bi-trash-fill"></i> Sí, eliminar
            </button>
        </form>
    </div>
</div>
