@model KineGestion.Web.Models.ViewModels.SessionViewModel

@{
    ViewData["Title"] = "Nueva Sesion";
}

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Registrar Nueva Sesion</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FechaHora" class="form-label fw-semibold"></label>
                            <input asp-for="FechaHora" type="datetime-local" class="form-control" />
                            <span asp-validation-for="FechaHora" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NroSesionEnTratamiento" class="form-label fw-semibold"></label>
                            <input asp-for="NroSesionEnTratamiento" class="form-control" />
                            <span asp-validation-for="NroSesionEnTratamiento" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label asp-for="PacienteId" class="form-label fw-semibold"></label>
                            <select asp-for="PacienteId" asp-items="Model.Pacientes" class="form-select">
                                <option value="">Seleccione paciente...</option>
                            </select>
                            <span asp-validation-for="PacienteId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProfesionalId" class="form-label fw-semibold"></label>
                            <select asp-for="ProfesionalId" asp-items="Model.Profesionales" class="form-select">
                                <option value="">Seleccione profesional...</option>
                            </select>
                            <span asp-validation-for="ProfesionalId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label asp-for="TratamientoId" class="form-label fw-semibold"></label>
                            <select asp-for="TratamientoId" asp-items="Model.Tratamientos" class="form-select">
                                <option value="">Seleccione tratamiento...</option>
                            </select>
                            <span asp-validation-for="TratamientoId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="EstadoPago" class="form-check-input" type="checkbox" />
                                <label asp-for="EstadoPago" class="form-check-label fw-semibold"></label>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-12">
                            <label asp-for="Observaciones" class="form-label fw-semibold"></label>
                            <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Observaciones" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
                        <button type="submit" class="btn btn-primary">Guardar Sesion</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
