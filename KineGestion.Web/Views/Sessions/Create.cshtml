@model KineGestion.Web.Models.ViewModels.SessionViewModel

@{
    ViewData["Title"] = "Nueva Sesión";
}

<div class="kg-page-header">
    <div>
        <h2>Nueva Sesión</h2>
        <p class="text-muted mb-0">Registrá una sesión clínica</p>
    </div>
    <a asp-action="Index" class="btn-kg-outline">
        <i class="bi bi-arrow-left"></i> Volver al listado
    </a>
</div>

<div class="kg-form-card">
    <div class="kg-form-header">
        <div class="kg-form-header-icon primary"><i class="bi bi-calendar2-plus-fill"></i></div>
        <div>
            <h4>Datos de la Sesión</h4>
            <p>Los campos marcados son obligatorios</p>
        </div>
    </div>
    <form asp-action="Create" method="post" data-loading-submit="true">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>
    <div class="kg-form-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FechaHora" class="form-label"></label>
                    <input asp-for="FechaHora" type="datetime-local" class="form-control" />
                    <span asp-validation-for="FechaHora" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PacienteId" class="form-label"></label>
                    <select asp-for="PacienteId" id="PacienteId" asp-items="Model.Pacientes" class="form-select">
                        <option value="">Seleccione paciente...</option>
                    </select>
                    <span asp-validation-for="PacienteId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ProfesionalId" class="form-label"></label>
                    <select asp-for="ProfesionalId" asp-items="Model.Profesionales" class="form-select">
                        <option value="">Seleccione profesional...</option>
                    </select>
                    <span asp-validation-for="ProfesionalId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="TratamientoId" class="form-label"></label>
                    <select asp-for="TratamientoId" id="TratamientoId" class="form-select" disabled>
                        <option value="">Primero seleccione un paciente...</option>
                    </select>
                    <span asp-validation-for="TratamientoId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="OfficeId" class="form-label"></label>
                    <select asp-for="OfficeId" asp-items="Model.Consultorios" class="form-select">
                        <option value="">Sin consultorio asignado</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" asp-items="Model.EstadosSesion" class="form-select"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="PaymentStatus" class="form-label"></label>
                    <select asp-for="PaymentStatus" asp-items="Model.EstadosPago" class="form-select"></select>
                </div>
                <div class="col-12">
                    <label asp-for="Observaciones" class="form-label"></label>
                    <textarea asp-for="Observaciones" class="form-control" rows="2" placeholder="Observaciones generales..."></textarea>
                    <span asp-validation-for="Observaciones" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Evolution" class="form-label">
                        <i class="bi bi-shield-lock-fill text-primary me-1"></i>@Html.DisplayNameFor(m => m.Evolution)
                        <span class="text-muted small ms-1">(solo profesionales)</span>
                    </label>
                    <textarea asp-for="Evolution" class="form-control" rows="4" placeholder="Registrá la evolución clínica del paciente..."></textarea>
                    <span asp-validation-for="Evolution" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="InternalNotes" class="form-label"></label>
                    <textarea asp-for="InternalNotes" class="form-control" rows="2" placeholder="Notas administrativas internas..."></textarea>
                    <span asp-validation-for="InternalNotes" class="text-danger small"></span>
                </div>
            </div>
    </div>
    <div class="kg-form-footer">
        <a asp-action="Index" class="btn-kg-outline"><i class="bi bi-x-lg"></i> Cancelar</a>
        <button type="submit" class="btn-kg-primary" data-loading-text="Guardando sesión..."><i class="bi bi-check-lg"></i> Guardar Sesión</button>
    </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
    (function () {
        const pacienteSelect    = document.getElementById('PacienteId');
        const tratamientoSelect = document.getElementById('TratamientoId');

        async function cargarTratamientos(patientId) {
            tratamientoSelect.innerHTML = '<option value="">Cargando...</option>';
            tratamientoSelect.disabled = true;
            if (!patientId) {
                tratamientoSelect.innerHTML = '<option value="">Primero seleccione un paciente...</option>';
                return;
            }
            try {
                const resp = await fetch(`/Sessions/ByPatient?patientId=${patientId}`);
                const data = await resp.json();
                tratamientoSelect.innerHTML = '<option value="">Seleccione tratamiento...</option>';
                data.forEach(t => {
                    const opt = document.createElement('option');
                    opt.value = t.id;
                    opt.textContent = t.descripcion;
                    tratamientoSelect.appendChild(opt);
                });
                if (data.length === 0) {
                    tratamientoSelect.innerHTML = '<option value="">Sin tratamientos para este paciente</option>';
                    tratamientoSelect.disabled = true;
                } else {
                    tratamientoSelect.disabled = false;
                }
            } catch {
                tratamientoSelect.innerHTML = '<option value="">Error al cargar</option>';
            }
        }

        pacienteSelect.addEventListener('change', () => cargarTratamientos(pacienteSelect.value));
    })();
    </script>
}
