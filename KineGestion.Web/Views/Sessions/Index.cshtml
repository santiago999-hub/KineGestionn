@model KineGestion.Web.Models.ViewModels.SessionIndexViewModel
@using KineGestion.Core

@{
    ViewData["Title"] = "Sesiones";
}

<div class="kg-page-header">
    <div>
        <h2>Sesiones</h2>
        <p class="text-muted mb-0">Registro de sesiones clínicas realizadas</p>
    </div>
    <a asp-action="Create" class="btn-kg-primary">
        <i class="bi bi-calendar2-plus-fill"></i> Nueva Sesión
    </a>
</div>

<div class="kg-card">
    <div class="kg-card-header">
        <h5 class="kg-card-header-title">
            <i class="bi bi-calendar2-check-fill"></i> Historial de Sesiones
        </h5>
        <span class="kg-badge kg-badge-muted">@Model.TotalCount registros</span>
    </div>

    <form method="get" class="px-3 pt-3 pb-1">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small text-muted">Buscar</label>
                <input name="search" value="@Model.Search" class="form-control" placeholder="Paciente, profesional o tratamiento" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted">Estado</label>
                <select name="status" class="form-select">
                    <option value="">Todos</option>
                    <option value="Pending" selected="@(Model.Status == SessionStatus.Pending)">Pendiente</option>
                    <option value="Completed" selected="@(Model.Status == SessionStatus.Completed)">Completada</option>
                    <option value="Canceled" selected="@(Model.Status == SessionStatus.Canceled)">Cancelada</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted">Pago</label>
                <select name="paymentStatus" class="form-select">
                    <option value="">Todos</option>
                    <option value="Pending" selected="@(Model.PaymentStatus == PaymentStatus.Pending)">Pendiente</option>
                    <option value="Paid" selected="@(Model.PaymentStatus == PaymentStatus.Paid)">Pagada</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted">Orden</label>
                <select name="sortBy" class="form-select">
                    <option value="fecha" selected="@(Model.SortBy == "fecha")">Fecha</option>
                    <option value="estado" selected="@(Model.SortBy == "estado")">Estado</option>
                </select>
                <input type="hidden" name="sortDir" value="@Model.SortDir" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn-kg-primary w-100"><i class="bi bi-search"></i></button>
                <a asp-action="Index" class="btn-kg-outline w-100"><i class="bi bi-x-lg"></i></a>
            </div>
        </div>
    </form>

    <div class="px-3 pb-2" style="display:flex;justify-content:flex-end">
        @{
            var nextDir = Model.SortDir == "asc" ? "desc" : "asc";
            var icon = Model.SortDir == "asc" ? "bi-sort-up" : "bi-sort-down";
        }
        <a asp-action="Index"
           asp-route-search="@Model.Search"
           asp-route-status="@Model.Status"
           asp-route-paymentStatus="@Model.PaymentStatus"
           asp-route-sortBy="@Model.SortBy"
           asp-route-sortDir="@nextDir"
           asp-route-page="1"
           asp-route-pageSize="@Model.PageSize"
           class="btn-kg-outline" style="font-size:.78rem">
            <i class="bi @icon"></i> Dirección: @(Model.SortDir == "asc" ? "Ascendente" : "Descendente")
        </a>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="kg-empty">
            <div class="kg-empty-icon"><i class="bi bi-calendar2-x"></i></div>
            <h5>Sin sesiones registradas</h5>
            <p>Registrá la primera sesión clínica del sistema.</p>
            <a asp-action="Create" class="btn-kg-primary">
                <i class="bi bi-calendar2-plus-fill"></i> Registrar la primera
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="kg-table">
                <thead>
                    <tr>
                        <th>Fecha y hora</th>
                        <th>Paciente</th>
                        <th>Profesional</th>
                        <th>Consultorio</th>
                        <th>Tratamiento</th>
                        <th>Nro</th>
                        <th>Estado</th>
                        <th>Pago</th>
                        <th style="text-align:right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Items)
                    {
                        <tr>
                            <td>
                                <div style="font-weight:600">@s.FechaHora.ToString("dd/MM/yyyy")</div>
                                <div style="font-size:.75rem;color:var(--kg-text-muted)">@s.FechaHora.ToString("HH:mm") hs</div>
                            </td>
                            <td>@s.PacienteNombre</td>
                            <td>@s.ProfesionalNombre</td>
                            <td>@(string.IsNullOrWhiteSpace(s.OfficeNombre) ? "Sin asignar" : s.OfficeNombre)</td>
                            <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@s.TratamientoDescripcion">
                                @s.TratamientoDescripcion
                            </td>
                            <td>
                                <span class="kg-badge kg-badge-violet">N° @s.NroSesionEnTratamiento</span>
                            </td>
                            <td>
                                @if (s.Status == SessionStatus.Completed)
                                {
                                    <span class="kg-badge kg-badge-success">Completada</span>
                                }
                                else if (s.Status == SessionStatus.Canceled)
                                {
                                    <span class="kg-badge kg-badge-danger">Cancelada</span>
                                }
                                else
                                {
                                    <span class="kg-badge kg-badge-warning">Pendiente</span>
                                }
                            </td>
                            <td>
                                @if (s.PaymentStatus == PaymentStatus.Paid)
                                {
                                    <span class="kg-badge kg-badge-success"><i class="bi bi-check-circle-fill"></i> Pagada</span>
                                }
                                else
                                {
                                    <span class="kg-badge kg-badge-warning"><i class="bi bi-clock-fill"></i> Pendiente</span>
                                }
                            </td>
                            <td>
                                <div class="kg-action-btns" style="justify-content:flex-end">
                                    <a asp-action="Details" asp-route-id="@s.Id" class="kg-action-btn view" title="Ver detalle"><i class="bi bi-eye-fill"></i></a>
                                    <a asp-action="Edit" asp-route-id="@s.Id" class="kg-action-btn edit" title="Editar"><i class="bi bi-pencil-fill"></i></a>
                                    <a asp-action="Delete" asp-route-id="@s.Id" class="kg-action-btn del" title="Eliminar"><i class="bi bi-trash-fill"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div style="padding:12px 18px;border-top:1px solid var(--kg-border);font-size:.76rem;color:var(--kg-text-muted)">
            Mostrando @Model.Items.Count() de @Model.TotalCount sesiones — pagadas: @Model.Items.Count(s => s.PaymentStatus == PaymentStatus.Paid) | pendientes: @Model.Items.Count(s => s.PaymentStatus == PaymentStatus.Pending)
        </div>

        @if (Model.TotalPages > 1)
        {
            <div style="padding:12px 18px;border-top:1px solid var(--kg-border);display:flex;justify-content:space-between;align-items:center;gap:8px;flex-wrap:wrap">
                <span style="font-size:.78rem;color:var(--kg-text-muted)">Página @Model.Page de @Model.TotalPages</span>
                <div style="display:flex;gap:6px">
                    <a asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-status="@Model.Status" asp-route-paymentStatus="@Model.PaymentStatus" asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir" class="btn-kg-outline @(Model.Page <= 1 ? "disabled" : "")">Anterior</a>
                    <a asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-status="@Model.Status" asp-route-paymentStatus="@Model.PaymentStatus" asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir" class="btn-kg-outline @(Model.Page >= Model.TotalPages ? "disabled" : "")">Siguiente</a>
                </div>
            </div>
        }
    }
</div>
