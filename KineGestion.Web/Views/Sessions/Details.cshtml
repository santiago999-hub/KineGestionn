@model KineGestion.Web.Models.ViewModels.SessionViewModel
@using KineGestion.Core

@{
    ViewData["Title"] = "Detalle de Sesión";
}

<div class="kg-page-header">
    <div>
        <h2>Detalle de Sesión</h2>
        <p class="text-muted mb-0">Información completa de la sesión clínica</p>
    </div>
    <a asp-action="Index" class="btn-kg-outline">
        <i class="bi bi-arrow-left"></i> Volver al listado
    </a>
</div>

<div class="kg-form-card">
    <div class="kg-form-header" style="justify-content:space-between">
        <div style="display:flex;align-items:center;gap:12px">
            <div style="width:48px;height:48px;border-radius:12px;background:#dbeafe;color:#2563eb;display:flex;align-items:center;justify-content:center;font-size:1.3rem">
                <i class="bi bi-calendar2-check-fill"></i>
            </div>
            <div>
                <h4 style="margin:0">@Model.PacienteNombre</h4>
                <p style="margin:0;font-size:.78rem;color:var(--kg-text-muted)">@Model.FechaHora.ToString("dd/MM/yyyy") a las @Model.FechaHora.ToString("HH:mm") hs</p>
            </div>
        </div>
        @if (Model.PaymentStatus == PaymentStatus.Paid)
        {
            <span class="kg-badge kg-badge-success"><i class="bi bi-check-circle-fill"></i> Pagada</span>
        }
        else
        {
            <span class="kg-badge kg-badge-warning"><i class="bi bi-clock-fill"></i> Pendiente</span>
        }
    </div>
    <div class="kg-form-body">
        <div class="kg-detail-grid">
            <div class="kg-detail-item">
                <dt>Fecha y hora</dt>
                <dd>@Model.FechaHora.ToString("dd/MM/yyyy HH:mm") hs</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Paciente</dt>
                <dd>@Model.PacienteNombre</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Profesional</dt>
                <dd>@Model.ProfesionalNombre</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Tratamiento</dt>
                <dd>@Model.TratamientoDescripcion</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Número de sesión</dt>
                <dd><span class="kg-badge kg-badge-violet">N° @Model.NroSesionEnTratamiento</span></dd>
            </div>
            <div class="kg-detail-item">
                <dt>Estado de pago</dt>
                <dd>
                    @if (Model.PaymentStatus == PaymentStatus.Paid)
                    {
                        <span class="kg-badge kg-badge-success"><i class="bi bi-check-circle-fill"></i> Pagada</span>
                    }
                    else
                    {
                        <span class="kg-badge kg-badge-warning"><i class="bi bi-clock-fill"></i> Pendiente</span>
                    }
                </dd>
            </div>
            <div class="kg-detail-item">
                <dt>Estado de sesión</dt>
                <dd>
                    @if (Model.Status == SessionStatus.Completed)
                    {
                        <span class="kg-badge kg-badge-success">Completada</span>
                    }
                    else if (Model.Status == SessionStatus.Canceled)
                    {
                        <span class="kg-badge kg-badge-danger">Cancelada</span>
                    }
                    else
                    {
                        <span class="kg-badge kg-badge-warning">Pendiente</span>
                    }
                </dd>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.OfficeNombre))
            {
                <div class="kg-detail-item">
                    <dt>Consultorio</dt>
                    <dd><i class="bi bi-building me-1"></i>@Model.OfficeNombre</dd>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Observaciones))
            {
                <div class="kg-detail-item" style="grid-column:1/-1">
                    <dt>Observaciones</dt>
                    <dd>@Model.Observaciones</dd>
                </div>
            }
        </div>

        @* ── Evolución Clínica (dato sensible) ─────────────────────────────── *@
        @if (!string.IsNullOrWhiteSpace(Model.Evolution))
        {
            <div class="mt-4">
                <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;overflow:hidden">
                    <button class="btn w-100 text-start d-flex align-items-center gap-2 px-4 py-3"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#evolutionCollapse"
                            aria-expanded="false"
                            aria-controls="evolutionCollapse"
                            style="background:transparent;border:none;font-weight:600;color:#1d4ed8">
                        <i class="bi bi-shield-lock-fill" style="color:#2563eb"></i>
                        Evolución Clínica
                        <span class="kg-badge kg-badge-muted ms-2" style="font-size:.7rem">Solo profesionales</span>
                        <i class="bi bi-chevron-down ms-auto"></i>
                    </button>
                    <div class="collapse" id="evolutionCollapse">
                        <div style="background:#fff;border-top:1px solid #bfdbfe;padding:1.25rem 1.5rem;white-space:pre-wrap;font-size:.93rem;color:#1e3a5f;line-height:1.7">
                            @Model.Evolution
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ── Notas Internas (área administrativa) ──────────────────────────── *@
        @if (!string.IsNullOrWhiteSpace(Model.InternalNotes))
        {
            <div class="mt-3">
                <div style="background:#fafaf9;border:1px solid #e7e5e4;border-radius:10px;padding:1rem 1.25rem">
                    <p style="margin:0 0 .4rem;font-weight:600;font-size:.82rem;color:#78716c;text-transform:uppercase;letter-spacing:.05em">
                        <i class="bi bi-sticky-fill me-1"></i>Notas Internas
                    </p>
                    <p style="margin:0;white-space:pre-wrap;font-size:.9rem;color:#57534e">@Model.InternalNotes</p>
                </div>
            </div>
        }

        <div class="mt-4" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:1rem 1.25rem">
            <p style="margin:0 0 .75rem;font-weight:700;font-size:.82rem;color:#475569;text-transform:uppercase;letter-spacing:.05em">
                <i class="bi bi-clock-history me-1"></i>Trazabilidad
            </p>
            <div class="kg-detail-grid">
                <div class="kg-detail-item">
                    <dt>Creada por</dt>
                    <dd>@Model.CreatedBy</dd>
                </div>
                <div class="kg-detail-item">
                    <dt>Creada el</dt>
                    <dd>@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                </div>
                <div class="kg-detail-item">
                    <dt>Última modificación por</dt>
                    <dd>@Model.UpdatedBy</dd>
                </div>
                <div class="kg-detail-item">
                    <dt>Última modificación</dt>
                    <dd>@Model.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                </div>
            </div>
        </div>
    </div>
    <div class="kg-form-footer">
        <a asp-action="Index" class="btn-kg-outline"><i class="bi bi-arrow-left"></i> Volver</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-kg-warning">
            <i class="bi bi-pencil-fill"></i> Editar
        </a>
    </div>
</div>
