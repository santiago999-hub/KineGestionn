@model KineGestion.Web.Models.ViewModels.ProfessionalViewModel

@{
    ViewData["Title"] = "Dar de Baja Profesional";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">Confirmar Baja</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    Estas por dar de baja al profesional <strong>@Model.Apellido, @Model.Nombre</strong>.
                    Sus datos quedaran inactivos y se conservara su historial.
                </div>

                <dl class="row">
                    <dt class="col-sm-4">Matricula</dt>
                    <dd class="col-sm-8">@Model.Matricula</dd>

                    <dt class="col-sm-4">Especialidad</dt>
                    <dd class="col-sm-8">@Model.Especialidad</dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Si, dar de baja</button>
                </form>
            </div>
        </div>
    </div>
</div>
