@model KineGestion.Web.Models.ViewModels.ProfessionalViewModel

@{
    ViewData["Title"] = "Detalle del Profesional";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Detalle del Profesional</h4>
                <span class="badge @(Model.IsActivo ? "bg-success" : "bg-secondary") fs-6">
                    @(Model.IsActivo ? "Activo" : "Inactivo")
                </span>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Apellido y Nombre</dt>
                    <dd class="col-sm-8">@Model.Apellido, @Model.Nombre</dd>

                    <dt class="col-sm-4">Matricula</dt>
                    <dd class="col-sm-8">@Model.Matricula</dd>

                    <dt class="col-sm-4">Especialidad</dt>
                    <dd class="col-sm-8">@Model.Especialidad</dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
            </div>
        </div>
    </div>
</div>
