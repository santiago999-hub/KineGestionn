@model KineGestion.Web.Models.ViewModels.ProfessionalIndexViewModel

@{
    ViewData["Title"] = "Profesionales";
}

<div class="kg-page-header">
    <div>
        <h2>Profesionales</h2>
        <p class="text-muted mb-0">Equipo de kinesiólogos y especialistas activos</p>
    </div>
    <a asp-action="Create" class="btn-kg-primary">
        <i class="bi bi-person-badge-fill"></i> Nuevo Profesional
    </a>
</div>

<div class="kg-card">
    <div class="kg-card-header">
        <h5 class="kg-card-header-title">
            <i class="bi bi-person-badge-fill"></i> Listado de Profesionales
        </h5>
        <span class="kg-badge kg-badge-muted">@Model.TotalCount registros</span>
    </div>

    <form method="get" class="px-3 pt-3 pb-1">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label small text-muted">Buscar</label>
                <input name="search" value="@Model.Search" class="form-control" placeholder="Nombre, matrícula o especialidad" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn-kg-primary w-100"><i class="bi bi-search"></i></button>
                <a asp-action="Index" class="btn-kg-outline w-100"><i class="bi bi-x-lg"></i></a>
            </div>
        </div>
    </form>

    @if (!Model.Items.Any())
    {
        <div class="kg-empty">
            <div class="kg-empty-icon"><i class="bi bi-person-badge"></i></div>
            <h5>Sin profesionales registrados</h5>
            <p>Registrá al primer kinesiólogo del centro.</p>
            <a asp-action="Create" class="btn-kg-primary">
                <i class="bi bi-person-plus-fill"></i> Registrar el primero
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="kg-table">
                <thead>
                    <tr>
                        <th>Profesional</th>
                        <th>Matrícula</th>
                        <th>Especialidad</th>
                        <th>Estado</th>
                        <th style="text-align:right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Items)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px">
                                    <div style="width:34px;height:34px;border-radius:50%;background:#e0f2fe;color:#0284c7;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:700;flex-shrink:0">
                                        @(p.Nombre.Length > 0 ? p.Nombre[0].ToString().ToUpper() : "?")@(p.Apellido.Length > 0 ? p.Apellido[0].ToString().ToUpper() : "")
                                    </div>
                                    <div>
                                        <div style="font-weight:600">@p.Apellido, @p.Nombre</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="kg-badge kg-badge-info">@p.Matricula</span></td>
                            <td>@p.Especialidad</td>
                            <td>
                                @if (p.IsActivo)
                                {
                                    <span class="kg-badge kg-badge-success"><i class="bi bi-circle-fill" style="font-size:.45rem"></i> Activo</span>
                                }
                                else
                                {
                                    <span class="kg-badge kg-badge-muted">Inactivo</span>
                                }
                            </td>
                            <td>
                                <div class="kg-action-btns" style="justify-content:flex-end">
                                    <a asp-action="Details" asp-route-id="@p.Id" class="kg-action-btn view" title="Ver detalle"><i class="bi bi-eye-fill"></i></a>
                                    <a asp-action="Edit" asp-route-id="@p.Id" class="kg-action-btn edit" title="Editar"><i class="bi bi-pencil-fill"></i></a>
                                    <a asp-action="Delete" asp-route-id="@p.Id" class="kg-action-btn del" title="Dar de baja"><i class="bi bi-trash-fill"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div style="padding:12px 18px;border-top:1px solid var(--kg-border);font-size:.76rem;color:var(--kg-text-muted)">
            Mostrando @Model.Items.Count() de @Model.TotalCount profesionales activos
        </div>

        @if (Model.TotalPages > 1)
        {
            <div style="padding:12px 18px;border-top:1px solid var(--kg-border);display:flex;justify-content:space-between;align-items:center;gap:8px;flex-wrap:wrap">
                <span style="font-size:.78rem;color:var(--kg-text-muted)">Página @Model.Page de @Model.TotalPages</span>
                <div style="display:flex;gap:6px">
                    <a asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" class="btn-kg-outline @(Model.Page <= 1 ? "disabled" : "")">Anterior</a>
                    <a asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" class="btn-kg-outline @(Model.Page >= Model.TotalPages ? "disabled" : "")">Siguiente</a>
                </div>
            </div>
        }
    }
</div>
