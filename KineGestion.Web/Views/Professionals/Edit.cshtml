@model KineGestion.Web.Models.ViewModels.ProfessionalViewModel

@{
    ViewData["Title"] = "Editar Profesional";
}

<div class="kg-page-header">
    <div>
        <h2>Editar Profesional</h2>
        <p class="text-muted mb-0">Modificá los datos del profesional</p>
    </div>
    <a asp-action="Index" class="btn-kg-outline">
        <i class="bi bi-arrow-left"></i> Volver al listado
    </a>
</div>

<div class="kg-form-card">
    <div class="kg-form-header">
        <div class="kg-form-header-icon" style="background:#fef9c3;color:#ca8a04"><i class="bi bi-pencil-fill"></i></div>
        <div>
            <h4>Editando: @Model.Apellido, @Model.Nombre</h4>
            <p>Matrícula @Model.Matricula</p>
        </div>
    </div>
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>
    <div class="kg-form-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Apellido" class="form-label"></label>
                    <input asp-for="Apellido" class="form-control" />
                    <span asp-validation-for="Apellido" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Matricula" class="form-label"></label>
                    <input asp-for="Matricula" class="form-control" />
                    <span asp-validation-for="Matricula" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Especialidad" class="form-label"></label>
                    <input asp-for="Especialidad" class="form-control" />
                    <span asp-validation-for="Especialidad" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActivo" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActivo" class="form-check-label"></label>
                    </div>
                </div>
            </div>
    </div>
    <div class="kg-form-footer">
        <a asp-action="Index" class="btn-kg-outline"><i class="bi bi-x-lg"></i> Cancelar</a>
        <button type="submit" class="btn-kg-primary"><i class="bi bi-check-lg"></i> Guardar Cambios</button>
    </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
