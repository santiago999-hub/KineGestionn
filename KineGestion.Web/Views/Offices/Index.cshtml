@model KineGestion.Web.Models.ViewModels.OfficeIndexViewModel

@{
    ViewData["Title"] = "Consultorios";
}

<div class="kg-page-header">
    <div>
        <h2>Consultorios</h2>
        <p class="text-muted mb-0">Gestión de espacios físicos del centro</p>
    </div>
    <a asp-action="Create" class="btn-kg-primary">
        <i class="bi bi-building-add"></i> Nuevo Consultorio
    </a>
</div>

<div class="kg-card">
    <div class="kg-card-header">
        <h5 class="kg-card-header-title">
            <i class="bi bi-building"></i> Listado de Consultorios
        </h5>
        <span class="kg-badge kg-badge-muted">@Model.TotalCount registros</span>
    </div>

    <form method="get" class="px-3 pt-3 pb-1">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label small text-muted">Buscar</label>
                <input name="search" value="@Model.Search" class="form-control" placeholder="Nombre del consultorio" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn-kg-primary w-100"><i class="bi bi-search"></i></button>
                <a asp-action="Index" class="btn-kg-outline w-100"><i class="bi bi-x-lg"></i></a>
            </div>
        </div>
    </form>

    @if (!Model.Items.Any())
    {
        <div class="kg-empty">
            <div class="kg-empty-icon"><i class="bi bi-building"></i></div>
            <h5>Sin consultorios registrados</h5>
            <p>Registrá el primer espacio del centro kinesiológico.</p>
            <a asp-action="Create" class="btn-kg-primary">
                <i class="bi bi-building-add"></i> Registrar el primero
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="kg-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Estado</th>
                        <th style="text-align:right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.Items)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px">
                                    <div style="width:34px;height:34px;border-radius:8px;background:#f0fdf4;color:#16a34a;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0">
                                        <i class="bi bi-building"></i>
                                    </div>
                                    <span style="font-weight:600">@o.Name</span>
                                </div>
                            </td>
                            <td>
                                @if (o.IsActive)
                                {
                                    <span class="kg-badge kg-badge-success"><i class="bi bi-check-circle-fill"></i> Activo</span>
                                }
                                else
                                {
                                    <span class="kg-badge kg-badge-warning"><i class="bi bi-pause-circle-fill"></i> Inactivo</span>
                                }
                            </td>
                            <td style="text-align:right">
                                <div style="display:flex;gap:6px;justify-content:flex-end">
                                    <a asp-action="Details" asp-route-id="@o.Id" class="kg-action-btn view" title="Ver detalle"><i class="bi bi-eye-fill"></i></a>
                                    <a asp-action="Edit" asp-route-id="@o.Id" class="kg-action-btn edit" title="Editar"><i class="bi bi-pencil-fill"></i></a>
                                    <a asp-action="Delete" asp-route-id="@o.Id" class="kg-action-btn del" title="Eliminar"><i class="bi bi-trash-fill"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div style="padding:12px 18px;border-top:1px solid var(--kg-border);font-size:.76rem;color:var(--kg-text-muted)">
            Mostrando @Model.Items.Count() de @Model.TotalCount consultorios
        </div>

        @if (Model.TotalPages > 1)
        {
            <div style="padding:12px 18px;border-top:1px solid var(--kg-border);display:flex;justify-content:space-between;align-items:center;gap:8px;flex-wrap:wrap">
                <span style="font-size:.78rem;color:var(--kg-text-muted)">Página @Model.Page de @Model.TotalPages</span>
                <div style="display:flex;gap:6px">
                    <a asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" class="btn-kg-outline @(Model.Page <= 1 ? "disabled" : "")">Anterior</a>
                    <a asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" class="btn-kg-outline @(Model.Page >= Model.TotalPages ? "disabled" : "")">Siguiente</a>
                </div>
            </div>
        }
    }
</div>
