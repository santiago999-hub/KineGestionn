@model KineGestion.Web.Models.ViewModels.ReminderCampaignViewModel

@{
    ViewData["Title"] = "Recordatorios";
}

<div class="kg-page-header">
    <div>
        <h2>Recordatorios de turnos</h2>
        <p class="text-muted mb-0">Ventana UTC: @Model.WindowStartUtc.ToString("dd/MM/yyyy HH:mm") - @Model.WindowEndUtc.ToString("dd/MM/yyyy HH:mm")</p>
        <p class="text-muted mb-0">Operativo diario: @Model.OperationalWindowsLabel | Elegibles: @Model.OperationalCandidatesCount</p>
    </div>
</div>

<div class="kg-card mb-3">
    <div class="kg-card-body">
        <form asp-action="DispatchOperational" method="post" class="d-flex justify-content-end mb-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="hoursAhead" value="@Model.HoursAhead" />
            <button type="submit" class="btn btn-success">
                <i class="bi bi-lightning-charge-fill"></i> Enviar operativo (@Model.OperationalWindowsLabel)
            </button>
        </form>

        <form asp-action="Index" method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Ventana próxima (horas)</label>
                <input type="number" min="1" max="168" name="hoursAhead" class="form-control" value="@Model.HoursAhead" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Actualizar</button>
            </div>
        </form>
    </div>
</div>

<div class="kg-card mb-3">
    <div class="kg-card-header">
        <h5 class="kg-card-header-title mb-0"><i class="bi bi-flask"></i> Prueba rápida de envío</h5>
    </div>
    <div class="kg-card-body">
        <form asp-action="SendTest" method="post" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <input type="hidden" name="hoursAhead" value="@Model.HoursAhead" />

            <div class="col-md-3">
                <label class="form-label">Sesión de muestra</label>
                <select name="sessionId" class="form-select">
                    <option value="">Primera de la lista</option>
                    @foreach (var item in Model.Items)
                    {
                        <option value="@item.SessionId">#@item.SessionId - @item.PacienteNombre (@item.FechaHora.ToString("dd/MM HH:mm"))</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Email test (opcional)</label>
                <input type="email" name="testEmail" class="form-control" placeholder="qa@tuclinica.com" />
            </div>
            <div class="col-md-3">
                <label class="form-label">WhatsApp test (opcional)</label>
                <input type="text" name="testPhone" class="form-control" placeholder="54911..." />
            </div>
            <div class="col-md-3">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" name="dryRun" value="true" checked id="dryRunCheck" />
                    <input type="hidden" name="dryRun" value="false" />
                    <label class="form-check-label" for="dryRunCheck">Dry-run (sin envío real)</label>
                </div>
                <button type="submit" class="btn btn-primary w-100">Ejecutar prueba</button>
            </div>
        </form>
    </div>
</div>

<div class="kg-card">
    <div class="kg-card-header d-flex justify-content-between align-items-center">
        <h5 class="kg-card-header-title mb-0"><i class="bi bi-send-check"></i> Campaña lista para enviar</h5>
        <span class="kg-badge kg-badge-info">@Model.Items.Count recordatorios</span>
    </div>
    <div class="kg-card-body">
        @if (!Model.Items.Any())
        {
            <div class="alert kg-alert-success mb-0">
                No hay sesiones pendientes de recordatorio dentro de la ventana seleccionada.
            </div>
        }
        else
        {
            <form asp-action="DispatchSelected" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="hoursAhead" value="@Model.HoursAhead" />

                <div class="d-flex justify-content-end mb-3">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-send"></i> Enviar seleccionados
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th style="width:48px;"><input type="checkbox" id="selectAll" /></th>
                                <th>Fecha/Hora</th>
                                <th>Paciente</th>
                                <th>Contacto</th>
                                <th>Canales</th>
                                <th>Profesional</th>
                                <th>Tratamiento</th>
                                <th>Acciones 1-click</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td><input type="checkbox" name="selectedSessionIds" value="@item.SessionId" class="session-check" /></td>
                                    <td>@item.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.PacienteNombre</td>
                                    <td>
                                        <div>@(string.IsNullOrWhiteSpace(item.PacienteEmail) ? "Sin email" : item.PacienteEmail)</div>
                                        <small class="text-muted">@(string.IsNullOrWhiteSpace(item.PacienteTelefono) ? "Sin telefono" : item.PacienteTelefono)</small>
                                    </td>
                                    <td>
                                        @if (item.CanEmail)
                                        {
                                            <span class="badge text-bg-info">Email</span>
                                        }
                                        @if (item.CanWhatsApp)
                                        {
                                            <span class="badge text-bg-success">WhatsApp</span>
                                        }
                                        @if (!item.CanEmail && !item.CanWhatsApp)
                                        {
                                            <span class="badge text-bg-secondary">Sin canal</span>
                                        }
                                    </td>
                                    <td>@item.ProfesionalNombre</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.TratamientoDescripcion) ? "-" : item.TratamientoDescripcion)</td>
                                    <td>
                                        <div class="d-flex flex-column gap-2">
                                            <a href="@item.ConfirmUrl" target="_blank" class="btn btn-sm btn-outline-success">Link confirmar</a>
                                            <a href="@item.CancelUrl" target="_blank" class="btn btn-sm btn-outline-danger">Link cancelar</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </form>
        }
    </div>
</div>

<div class="kg-card mt-3">
    <div class="kg-card-header d-flex justify-content-between align-items-center">
        <h5 class="kg-card-header-title mb-0"><i class="bi bi-clock-history"></i> Historial reciente de envíos</h5>
        <span class="kg-badge kg-badge-info">@Model.History.Count eventos</span>
    </div>
    <div class="kg-card-body">
        @if (!Model.History.Any())
        {
            <div class="alert kg-alert-success mb-0">Todavía no hay eventos de envío registrados.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Fecha UTC</th>
                            <th>Usuario</th>
                            <th>Sesión</th>
                            <th>Canal</th>
                            <th>Estado</th>
                            <th>Detalle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in Model.History)
                        {
                            <tr>
                                <td>@h.ChangedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@h.ChangedBy</td>
                                <td>#@h.SessionId</td>
                                <td>@h.ChannelSummary</td>
                                <td>
                                    @if (h.Status == "Enviado")
                                    {
                                        <span class="badge text-bg-success">Enviado</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-danger">Error</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(h.ErrorSummary))
                                    {
                                        <small class="text-muted">@h.ErrorSummary</small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">-</small>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const selectAll = document.getElementById('selectAll');
        if (selectAll) {
            selectAll.addEventListener('change', function () {
                document.querySelectorAll('.session-check').forEach(cb => cb.checked = this.checked);
            });
        }
    </script>
}
