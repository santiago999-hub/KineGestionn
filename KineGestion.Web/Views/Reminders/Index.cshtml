@model KineGestion.Web.Models.ViewModels.ReminderCampaignViewModel

@{
    ViewData["Title"] = "Recordatorios";
}

<div class="kg-page-header">
    <div>
        <h2>Recordatorios de turnos</h2>
        <p class="text-muted mb-0">Ventana UTC: @Model.WindowStartUtc.ToString("dd/MM/yyyy HH:mm") - @Model.WindowEndUtc.ToString("dd/MM/yyyy HH:mm")</p>
    </div>
</div>

<div class="kg-card">
    <div class="kg-card-header d-flex justify-content-between align-items-center">
        <h5 class="kg-card-header-title mb-0"><i class="bi bi-send-check"></i> Campaña lista para enviar</h5>
        <span class="kg-badge kg-badge-info">@Model.Items.Count recordatorios</span>
    </div>
    <div class="kg-card-body">
        @if (!Model.Items.Any())
        {
            <div class="alert kg-alert-success mb-0">
                No hay sesiones pendientes de recordatorio dentro de la ventana seleccionada.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Fecha/Hora</th>
                            <th>Paciente</th>
                            <th>Contacto</th>
                            <th>Profesional</th>
                            <th>Tratamiento</th>
                            <th>Acciones 1-click</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.PacienteNombre</td>
                                <td>
                                    <div>@(string.IsNullOrWhiteSpace(item.PacienteEmail) ? "Sin email" : item.PacienteEmail)</div>
                                    <small class="text-muted">@(string.IsNullOrWhiteSpace(item.PacienteTelefono) ? "Sin telefono" : item.PacienteTelefono)</small>
                                </td>
                                <td>@item.ProfesionalNombre</td>
                                <td>@(string.IsNullOrWhiteSpace(item.TratamientoDescripcion) ? "-" : item.TratamientoDescripcion)</td>
                                <td>
                                    <div class="d-flex flex-column gap-2">
                                        <a href="@item.ConfirmUrl" target="_blank" class="btn btn-sm btn-outline-success">Link confirmar</a>
                                        <a href="@item.CancelUrl" target="_blank" class="btn btn-sm btn-outline-danger">Link cancelar</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
