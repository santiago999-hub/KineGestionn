@model ErrorViewModel
@{
    ViewData["Title"] = "Error del Sistema";
}

<div class="kg-page-header">
    <div>
        <h2>Error del Sistema</h2>
        <p class="text-muted mb-0">No pudimos procesar tu solicitud</p>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn-kg-outline">
        <i class="bi bi-house-fill"></i> Volver al inicio
    </a>
</div>

<section class="kg-status-page kg-card kg-status-page-error">
    <div class="kg-status-icon">
        <i class="bi bi-exclamation-octagon"></i>
    </div>
    <h4>Algo salió mal</h4>
    <p class="text-muted mb-0">El incidente fue registrado para revisión técnica.</p>

    <div class="kg-status-message">
        @Model.FriendlyMessage
    </div>

    @if (Model.ShowRequestId)
    {
        <p class="kg-status-request-id mb-0">
            ID de solicitud: <strong>@Model.RequestId</strong>
        </p>
    }

    <div class="kg-status-actions">
        <a asp-controller="Home" asp-action="Index" class="btn-kg-primary">
            <i class="bi bi-arrow-repeat"></i> Reintentar
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn-kg-outline">
            <i class="bi bi-house-door"></i> Volver al inicio
        </a>
    </div>
</section>

<section class="kg-status-help">
    <h5>Recomendaciones rápidas</h5>
    <ul>
        <li>Intentá nuevamente en unos segundos.</li>
        <li>Si el error persiste, informá el ID de solicitud al equipo técnico.</li>
    </ul>
</section>
