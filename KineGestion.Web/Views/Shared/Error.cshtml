@model ErrorViewModel
@{
    ViewData["Title"] = "Error del Sistema";
}

<div class="kg-page-header">
    <div>
        <h2>Error del Sistema</h2>
        <p class="text-muted mb-0">No pudimos procesar tu solicitud</p>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn-kg-outline">
        <i class="bi bi-house-fill"></i> Volver al inicio
    </a>
</div>

<div class="kg-form-card">
    <div class="kg-form-header" style="background:#fef2f2">
        <div class="kg-form-header-icon" style="background:#fee2e2;color:#dc2626">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <div>
            <h4>Algo salió mal</h4>
            <p>El error fue registrado para su revisión.</p>
        </div>
    </div>
    <div class="kg-form-body">
        <p style="margin:0;font-size:.92rem">@Model.FriendlyMessage</p>
        @if (Model.ShowRequestId)
        {
            <p class="mt-3 mb-0" style="font-size:.8rem;color:var(--kg-text-muted)">
                ID de solicitud: <strong>@Model.RequestId</strong>
            </p>
        }
    </div>
    <div class="kg-form-footer">
        <a asp-controller="Home" asp-action="Index" class="btn-kg-primary">
            <i class="bi bi-arrow-repeat"></i> Reintentar
        </a>
    </div>
</div>
