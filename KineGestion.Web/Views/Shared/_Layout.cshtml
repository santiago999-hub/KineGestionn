<!DOCTYPE html>
<html lang="es">
@using System.Globalization
@using KineGestion.Web.Localization
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KineGestión</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Serif:wght@500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="kg-theme-professional" id="kgBody">
    @{
        var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        var returnUrl = (Context?.Request?.Path.Value ?? "/") + (Context?.Request?.QueryString.Value ?? string.Empty);
    }

    <!-- SIDEBAR -->
    <aside class="kg-sidebar" id="sidebar">
        <div class="kg-sidebar-brand">
            <div class="kg-sidebar-logo">
                <i class="bi bi-heart-pulse-fill"></i>
            </div>
            <div>
                <span class="kg-sidebar-title">KineGestión</span>
                <span class="kg-sidebar-subtitle">@LayoutText.Get("Brand.Center", "Unidad de Kinesiología")</span>
            </div>
        </div>

        <nav class="kg-sidebar-nav">
            <div class="kg-nav-section-label">@LayoutText.Get("Nav.Main", "Panel Clínico")</div>
            <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
               asp-controller="Home" asp-action="Index">
                <i class="bi bi-speedometer2"></i>
                <span>@LayoutText.Get("Nav.Dashboard", "Panel Ejecutivo")</span>
            </a>

            <div class="kg-nav-section-label">@LayoutText.Get("Nav.Management", "Operación Clínica")</div>
            @if (User.IsInRole("Admin"))
            {
                <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Patients" ? "active" : "")"
                   asp-controller="Patients" asp-action="Index">
                    <i class="bi bi-person-lines-fill"></i>
                    <span>@LayoutText.Get("Nav.Patients", "Pacientes")</span>
                </a>
            }
            @if (User.IsInRole("Kinesiologo"))
            {
                <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sessions" && ViewContext.RouteData.Values["action"]?.ToString() == "MyAgenda" ? "active" : "")"
                   asp-controller="Sessions" asp-action="MyAgenda">
                    <i class="bi bi-calendar2-week-fill"></i>
                    <span>@LayoutText.Get("Nav.MyAgenda", "Mi Agenda")</span>
                </a>
            }
            <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Professionals" ? "active" : "")"
               asp-controller="Professionals" asp-action="Index">
                <i class="bi bi-person-workspace"></i>
                <span>@LayoutText.Get("Nav.Professionals", "Equipo Clínico")</span>
            </a>
            <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Treatments" ? "active" : "")"
               asp-controller="Treatments" asp-action="Index">
                <i class="bi bi-clipboard2-pulse"></i>
                <span>@LayoutText.Get("Nav.Treatments", "Planes Terapéuticos")</span>
            </a>
            <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sessions" ? "active" : "")"
               asp-controller="Sessions" asp-action="Index">
                <i class="bi bi-calendar2-check"></i>
                <span>@LayoutText.Get("Nav.Sessions", "Agenda de Sesiones")</span>
            </a>
            <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Offices" ? "active" : "")"
               asp-controller="Offices" asp-action="Index">
                <i class="bi bi-hospital"></i>
                <span>@LayoutText.Get("Nav.Offices", "Salas y Consultorios")</span>
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div class="kg-nav-section-label">@LayoutText.Get("Nav.Admin", "Seguridad y Control")</div>
                <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                   asp-controller="Users" asp-action="Index">
                    <i class="bi bi-people"></i>
                    <span>@LayoutText.Get("Nav.Users", "Gestión de Usuarios")</span>
                </a>
                <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Audit" ? "active" : "")"
                   asp-controller="Audit" asp-action="Index">
                    <i class="bi bi-shield-check"></i>
                    <span>@LayoutText.Get("Nav.Audit", "Trazabilidad y Auditoría")</span>
                </a>
            }
        </nav>

        <div class="kg-sidebar-footer">
            <i class="bi bi-circle-fill text-success me-1 kg-status-dot"></i>
            @LayoutText.Get("Status.Operating", "Sistema Operativo")
        </div>
    </aside>

    <!-- MAIN WRAPPER -->
    <div class="kg-main-wrapper">

        <!-- TOPBAR -->
        <header class="kg-topbar">
            <button class="kg-sidebar-toggle d-lg-none" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>
            <div class="kg-topbar-title">
                <h6 class="mb-0 fw-semibold">@(ViewData["Title"] ?? "Dashboard")</h6>
            </div>
            <div class="kg-topbar-right">
                <form asp-controller="Localization" asp-action="SetLanguage" method="post" class="d-inline me-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <select name="culture" class="form-select form-select-sm kg-language-select" onchange="this.form.submit()" aria-label="Idioma">
                        <option value="es" selected="@(currentCulture == "es")">ES</option>
                        <option value="en" selected="@(currentCulture == "en")">EN</option>
                    </select>
                </form>
                <button type="button" class="kg-topbar-badge kg-theme-toggle" id="themeToggle" title="@LayoutText.Get("Action.SwitchTheme", "Cambiar tema visual")" aria-label="@LayoutText.Get("Action.SwitchTheme", "Cambiar tema visual")">
                    <i class="bi bi-circle-half"></i>
                </button>
                <span class="kg-topbar-badge">
                    <i class="bi bi-bell"></i>
                </span>
                <a asp-controller="Account" asp-action="Profile" class="kg-topbar-user kg-topbar-user-link" title="@LayoutText.Get("Action.Profile", "Ver perfil")">
                    <div class="kg-avatar">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <span class="d-none d-md-inline">@User.Identity?.Name</span>
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline ms-2">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link p-0 kg-logout-btn" title="@LayoutText.Get("Action.Logout", "Cerrar sesión")">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </header>

        <!-- CONTENT -->
        <main class="kg-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert kg-alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert kg-alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                </div>
            }
            @RenderBody()
        </main>

        <footer class="kg-footer">
            &copy; 2026 KineGestión &mdash; @LayoutText.Get("Footer.Text", "Sistema de Gestión Clínica - Todos los derechos reservados.")
        </footer>
    </div>

    <!-- Overlay mobile -->
    <div class="kg-overlay d-lg-none" id="sidebarOverlay"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const toggle = document.getElementById('sidebarToggle');
        const overlay = document.getElementById('sidebarOverlay');
        const sidebar = document.getElementById('sidebar');

        if (toggle) {
            toggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
                overlay.classList.toggle('show');
            });
            overlay.addEventListener('click', () => {
                sidebar.classList.remove('show');
                overlay.classList.remove('show');
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
