<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KineGestión</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="kg-sidebar" id="sidebar">
        <div class="kg-sidebar-brand">
            <div class="kg-sidebar-logo">
                <i class="bi bi-heart-pulse-fill"></i>
            </div>
            <div>
                <span class="kg-sidebar-title">KineGestión</span>
                <span class="kg-sidebar-subtitle">Centro de Kinesiología</span>
            </div>
        </div>

        <nav class="kg-sidebar-nav">
            <div class="kg-nav-section-label">Principal</div>
            <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
               asp-controller="Home" asp-action="Index">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Dashboard</span>
            </a>

            <div class="kg-nav-section-label">Gestión</div>
            <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Patients" ? "active" : "")"
               asp-controller="Patients" asp-action="Index">
                <i class="bi bi-people-fill"></i>
                <span>Pacientes</span>
            </a>
            <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Professionals" ? "active" : "")"
               asp-controller="Professionals" asp-action="Index">
                <i class="bi bi-person-badge-fill"></i>
                <span>Profesionales</span>
            </a>
            <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Treatments" ? "active" : "")"
               asp-controller="Treatments" asp-action="Index">
                <i class="bi bi-journal-medical"></i>
                <span>Tratamientos</span>
            </a>
            <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sessions" ? "active" : "")"
               asp-controller="Sessions" asp-action="Index">
                <i class="bi bi-calendar2-check-fill"></i>
                <span>Sesiones</span>
            </a>
            <a class="kg-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Offices" ? "active" : "")"
               asp-controller="Offices" asp-action="Index">
                <i class="bi bi-building"></i>
                <span>Consultorios</span>
            </a>
        </nav>

        <div class="kg-sidebar-footer">
            <i class="bi bi-circle-fill text-success me-1" style="font-size:.55rem"></i>
            Sistema Operativo
        </div>
    </aside>

    <!-- MAIN WRAPPER -->
    <div class="kg-main-wrapper">

        <!-- TOPBAR -->
        <header class="kg-topbar">
            <button class="kg-sidebar-toggle d-lg-none" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>
            <div class="kg-topbar-title">
                <h6 class="mb-0 fw-semibold">@(ViewData["Title"] ?? "Dashboard")</h6>
            </div>
            <div class="kg-topbar-right">
                <span class="kg-topbar-badge">
                    <i class="bi bi-bell"></i>
                </span>
                <div class="kg-topbar-user">
                    <div class="kg-avatar">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <span class="d-none d-md-inline">@User.Identity?.Name</span>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline ms-2">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link p-0" style="color:var(--kg-text-muted);font-size:.85rem" title="Cerrar sesión">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </header>

        <!-- CONTENT -->
        <main class="kg-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert kg-alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert kg-alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                </div>
            }
            @RenderBody()
        </main>

        <footer class="kg-footer">
            &copy; 2026 KineGestión &mdash; Sistema de Gestión Clínica &mdash; Todos los derechos reservados.
        </footer>
    </div>

    <!-- Overlay mobile -->
    <div class="kg-overlay d-lg-none" id="sidebarOverlay"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const toggle = document.getElementById('sidebarToggle');
        const overlay = document.getElementById('sidebarOverlay');
        const sidebar = document.getElementById('sidebar');
        if (toggle) {
            toggle.addEventListener('click', () => {
                sidebar.classList.toggle('show');
                overlay.classList.toggle('show');
            });
            overlay.addEventListener('click', () => {
                sidebar.classList.remove('show');
                overlay.classList.remove('show');
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
