@model KineGestion.Web.Models.ViewModels.UserIndexViewModel

@{
    ViewData["Title"] = "Usuarios";
}

<div class="kg-page-header">
    <div>
        <h2>Usuarios del sistema</h2>
        <p class="text-muted mb-0">Gestión de cuentas y roles de acceso</p>
    </div>
    <a asp-action="Create" class="btn-kg-primary">
        <i class="bi bi-person-plus-fill"></i> Nuevo Usuario
    </a>
</div>

<div class="kg-card">
    <div class="kg-card-header">
        <h5 class="kg-card-header-title">
            <i class="bi bi-people-fill"></i> Listado de Usuarios
        </h5>
        <span class="kg-badge kg-badge-muted">@Model.TotalCount registros</span>
    </div>

    <form method="get" class="px-3 pt-3 pb-1">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label small text-muted">Buscar por email</label>
                <input name="search" value="@Model.Search" class="form-control" placeholder="usuario@dominio.com" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn-kg-primary w-100"><i class="bi bi-search"></i></button>
                <a asp-action="Index" class="btn-kg-outline w-100"><i class="bi bi-x-lg"></i></a>
            </div>
        </div>
    </form>

    @if (!Model.Items.Any())
    {
        <div class="kg-empty">
            <div class="kg-empty-icon"><i class="bi bi-person-x"></i></div>
            <h5>Sin usuarios registrados</h5>
            <p>Creá el primer usuario del sistema.</p>
            <a asp-action="Create" class="btn-kg-primary">
                <i class="bi bi-person-plus-fill"></i> Crear el primero
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="kg-table">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th style="text-align:right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Items)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px">
                                    <div style="width:34px;height:34px;border-radius:50%;background:#ede9fe;color:#7c3aed;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                    <div style="font-weight:600">@u.Email</div>
                                </div>
                            </td>
                            <td>
                                @if (u.Rol == "Admin")
                                {
                                    <span class="kg-badge kg-badge-violet"><i class="bi bi-shield-fill me-1"></i>Admin</span>
                                }
                                else if (u.Rol == "Kinesiologo")
                                {
                                    <span class="kg-badge kg-badge-info"><i class="bi bi-person-badge-fill me-1"></i>Kinesiólogo</span>
                                }
                                else
                                {
                                    <span class="kg-badge kg-badge-muted">@u.Rol</span>
                                }
                            </td>
                            <td>
                                @if (u.EmailConfirmed)
                                {
                                    <span class="kg-badge kg-badge-success"><i class="bi bi-check-circle-fill me-1"></i>Activo</span>
                                }
                                else
                                {
                                    <span class="kg-badge kg-badge-warning"><i class="bi bi-clock-fill me-1"></i>Pendiente</span>
                                }
                            </td>
                            <td>
                                <div class="kg-action-btns" style="justify-content:flex-end">
                                    <a asp-action="Edit" asp-route-id="@u.Id" class="kg-action-btn edit" title="Editar"><i class="bi bi-pencil-fill"></i></a>
                                    <a asp-action="Delete" asp-route-id="@u.Id" class="kg-action-btn del" title="Eliminar"><i class="bi bi-trash-fill"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div style="padding:12px 18px;border-top:1px solid var(--kg-border);font-size:.76rem;color:var(--kg-text-muted)">
            Mostrando @Model.Items.Count() de @Model.TotalCount usuarios
        </div>

        @if (Model.TotalPages > 1)
        {
            <div style="padding:12px 18px;border-top:1px solid var(--kg-border);display:flex;justify-content:space-between;align-items:center;gap:8px;flex-wrap:wrap">
                <span style="font-size:.78rem;color:var(--kg-text-muted)">Página @Model.Page de @Model.TotalPages</span>
                <div style="display:flex;gap:6px">
                    <a asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" class="btn-kg-outline @(Model.Page <= 1 ? "disabled" : "")">Anterior</a>
                    <a asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" class="btn-kg-outline @(Model.Page >= Model.TotalPages ? "disabled" : "")">Siguiente</a>
                </div>
            </div>
        }
    }
</div>
