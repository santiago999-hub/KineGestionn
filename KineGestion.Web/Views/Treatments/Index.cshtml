@model KineGestion.Web.Models.ViewModels.TreatmentIndexViewModel

@{
    ViewData["Title"] = "Tratamientos";
}

<div class="kg-page-header">
    <div>
        <h2>Tratamientos</h2>
        <p class="text-muted mb-0">Planes terapéuticos asignados a pacientes</p>
    </div>
    <a asp-action="Create" class="btn-kg-primary">
        <i class="bi bi-journal-plus"></i> Nuevo Tratamiento
    </a>
</div>

<div class="kg-card">
    <div class="kg-card-header">
        <h5 class="kg-card-header-title">
            <i class="bi bi-journal-medical"></i> Listado de Tratamientos
        </h5>
        <span class="kg-badge kg-badge-muted">@Model.TotalCount registros</span>
    </div>

    <form method="get" class="px-3 pt-3 pb-1">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label small text-muted">Buscar</label>
                <input name="search" value="@Model.Search" class="form-control" placeholder="Descripción o nombre de paciente" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn-kg-primary w-100"><i class="bi bi-search"></i></button>
                <a asp-action="Index" class="btn-kg-outline w-100"><i class="bi bi-x-lg"></i></a>
            </div>
        </div>
    </form>

    @if (!Model.Items.Any())
    {
        <div class="kg-empty">
            <div class="kg-empty-icon"><i class="bi bi-journal-medical"></i></div>
            <h5>Sin tratamientos registrados</h5>
            <p>Creá el primer plan terapéutico para un paciente.</p>
            <a asp-action="Create" class="btn-kg-primary">
                <i class="bi bi-journal-plus"></i> Crear el primero
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="kg-table">
                <thead>
                    <tr>
                        <th>Tratamiento</th>
                        <th>Paciente</th>
                        <th>Progreso</th>
                        <th>Fecha inicio</th>
                        <th style="text-align:right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Items)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px">
                                    <div style="width:34px;height:34px;border-radius:10px;background:#dcfce7;color:#16a34a;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0">
                                        <i class="bi bi-journal-medical"></i>
                                    </div>
                                    <div style="font-weight:600">@t.Descripcion</div>
                                </div>
                            </td>
                            <td>@(t.PacienteNombre ?? "—")</td>
                            <td>
                                @{
                                    var pct = t.CantidadSesionesTotales > 0
                                        ? (int)Math.Round((double)t.SesionesRealizadas / t.CantidadSesionesTotales * 100)
                                        : 0;
                                    var barColor = pct >= 100 ? "#16a34a" : pct >= 50 ? "#2563eb" : "#f59e0b";
                                }
                                <div style="min-width:130px">
                                    <div style="display:flex;justify-content:space-between;font-size:.76rem;margin-bottom:4px">
                                        <span style="font-weight:600;color:var(--kg-text)">@t.SesionesRealizadas / @t.CantidadSesionesTotales</span>
                                        <span style="color:var(--kg-text-muted)">@pct%</span>
                                    </div>
                                    <div style="height:6px;border-radius:99px;background:var(--kg-border)">
                                        <div style="height:6px;border-radius:99px;width:@(pct)%;background:@barColor;transition:width .3s"></div>
                                    </div>
                                </div>
                            </td>
                            <td>@t.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="kg-action-btns" style="justify-content:flex-end">
                                    <a asp-action="Details" asp-route-id="@t.Id" class="kg-action-btn view" title="Ver detalle"><i class="bi bi-eye-fill"></i></a>
                                    <a asp-action="Edit" asp-route-id="@t.Id" class="kg-action-btn edit" title="Editar"><i class="bi bi-pencil-fill"></i></a>
                                    <a asp-action="Delete" asp-route-id="@t.Id" class="kg-action-btn del" title="Eliminar"><i class="bi bi-trash-fill"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div style="padding:12px 18px;border-top:1px solid var(--kg-border);font-size:.76rem;color:var(--kg-text-muted)">
            Mostrando @Model.Items.Count() de @Model.TotalCount tratamientos
        </div>

        @if (Model.TotalPages > 1)
        {
            <div style="padding:12px 18px;border-top:1px solid var(--kg-border);display:flex;justify-content:space-between;align-items:center;gap:8px;flex-wrap:wrap">
                <span style="font-size:.78rem;color:var(--kg-text-muted)">Página @Model.Page de @Model.TotalPages</span>
                <div style="display:flex;gap:6px">
                    <a asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" class="btn-kg-outline @(Model.Page <= 1 ? "disabled" : "")">Anterior</a>
                    <a asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" class="btn-kg-outline @(Model.Page >= Model.TotalPages ? "disabled" : "")">Siguiente</a>
                </div>
            </div>
        }
    }
</div>
