@model KineGestion.Web.Models.ViewModels.TreatmentViewModel

@{
    ViewData["Title"] = "Nuevo Tratamiento";
}

<div class="kg-page-header">
    <div>
        <h2>Nuevo Tratamiento</h2>
        <p class="text-muted mb-0">Creá un plan terapéutico para un paciente</p>
    </div>
    <a asp-action="Index" class="btn-kg-outline">
        <i class="bi bi-arrow-left"></i> Volver al listado
    </a>
</div>

<div class="kg-form-card">
    <div class="kg-form-header">
        <div class="kg-form-header-icon" style="background:#dcfce7;color:#16a34a"><i class="bi bi-journal-plus"></i></div>
        <div>
            <h4>Datos del Tratamiento</h4>
            <p>Los campos marcados son obligatorios</p>
        </div>
    </div>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>
    <div class="kg-form-body">
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Descripcion" class="form-label"></label>
                    <input asp-for="Descripcion" class="form-control" placeholder="Ej: Rehabilitación lumbar — 10 sesiones" />
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="CantidadSesionesTotales" class="form-label"></label>
                    <input asp-for="CantidadSesionesTotales" class="form-control" type="number" min="1" max="365" placeholder="Ej: 10" />
                    <span asp-validation-for="CantidadSesionesTotales" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FechaInicio" class="form-label"></label>
                    <input asp-for="FechaInicio" class="form-control" type="date" />
                    <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="PacienteId" class="form-label"></label>
                    <select asp-for="PacienteId" asp-items="Model.Pacientes" class="form-select">
                        <option value="">Seleccione paciente...</option>
                    </select>
                    <span asp-validation-for="PacienteId" class="text-danger small"></span>
                </div>
            </div>
    </div>
    <div class="kg-form-footer">
        <a asp-action="Index" class="btn-kg-outline"><i class="bi bi-x-lg"></i> Cancelar</a>
        <button type="submit" class="btn-kg-primary"><i class="bi bi-check-lg"></i> Guardar Tratamiento</button>
    </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
