@model KineGestion.Web.Models.ViewModels.PatientViewModel

@{
    ViewData["Title"] = "Nuevo Paciente";
}

<div class="kg-page-header">
    <div>
        <h2>Nuevo Paciente</h2>
        <p class="text-muted mb-0">Completá los datos para registrar al paciente</p>
    </div>
    <a asp-action="Index" class="btn-kg-outline">
        <i class="bi bi-arrow-left"></i> Volver al listado
    </a>
</div>

<div class="kg-form-card">
    <div class="kg-form-header">
        <div class="kg-form-header-icon primary"><i class="bi bi-person-plus-fill"></i></div>
        <div>
            <h4>Datos del Paciente</h4>
            <p>Los campos marcados son obligatorios</p>
        </div>
    </div>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>
    <div class="kg-form-body">

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Juan" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Apellido" class="form-label"></label>
                    <input asp-for="Apellido" class="form-control" placeholder="Ej: Pérez" />
                    <span asp-validation-for="Apellido" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DNI" class="form-label"></label>
                    <input asp-for="DNI" class="form-control" placeholder="Ej: 35123456" maxlength="8" />
                    <span asp-validation-for="DNI" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FechaNacimiento" class="form-label"></label>
                    <input asp-for="FechaNacimiento" class="form-control" type="date" />
                    <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="ObraSocial" class="form-label"></label>
                    <input asp-for="ObraSocial" id="obraSocialInput" class="form-control" placeholder="Ej: OSDE, PAMI — dejar vacío si es particular" />
                    <span asp-validation-for="ObraSocial" class="text-danger small"></span>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="sinObraSocial" />
                        <label class="form-check-label text-muted" style="font-size:.8rem" for="sinObraSocial">
                            Paciente particular (sin obra social)
                        </label>
                    </div>
                </div>
                <div class="col-md-6">
                    <label asp-for="Telefono" class="form-label"></label>
                    <input asp-for="Telefono" class="form-control" placeholder="Ej: 2215551234" />
                    <span asp-validation-for="Telefono" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="Ej: juan@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>
    </div>
    <div class="kg-form-footer">
        <a asp-action="Index" class="btn-kg-outline"><i class="bi bi-x-lg"></i> Cancelar</a>
        <button type="submit" class="btn-kg-primary"><i class="bi bi-check-lg"></i> Guardar Paciente</button>
    </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const chk = document.getElementById('sinObraSocial');
        const input = document.getElementById('obraSocialInput');
        chk.addEventListener('change', function () {
            if (this.checked) {
                input.value = '';
                input.placeholder = 'Paciente particular';
            } else {
                input.placeholder = 'Ej: OSDE, PAMI — dejar vacío si es particular';
                input.focus();
            }
        });
    </script>
}
