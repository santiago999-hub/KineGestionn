@model KineGestion.Web.Models.ViewModels.PatientViewModel

@{
    ViewData["Title"] = "Dar de Baja Paciente";
}

<div class="kg-page-header">
    <div>
        <h2>Dar de Baja Paciente</h2>
        <p class="text-muted mb-0">Baja lógica — los datos se conservan</p>
    </div>
    <a asp-action="Index" class="btn-kg-outline">
        <i class="bi bi-arrow-left"></i> Cancelar
    </a>
</div>

<div class="kg-form-card" style="border-top: 3px solid var(--kg-danger)">
    <div class="kg-form-header" style="background:#fff5f5">
        <div class="kg-form-header-icon" style="background:#fee2e2;color:#dc2626"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <div>
            <h4>¿Confirmar baja lógica?</h4>
            <p style="color:#dc2626">Esta acción desactivará a <strong>@Model.Apellido, @Model.Nombre</strong> pero conservará su historial clínico por seguridad legal.</p>
        </div>
    </div>
    @if ((int)ViewBag.TreatmentCount > 0 || (int)ViewBag.SessionCount > 0)
    {
        <div class="alert alert-warning mx-4 mt-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>No se puede dar de baja a este paciente</strong> porque tiene
            @if ((int)ViewBag.TreatmentCount > 0)
            {
                <strong>@ViewBag.TreatmentCount tratamiento(s)</strong>
            }
            @if ((int)ViewBag.TreatmentCount > 0 && (int)ViewBag.SessionCount > 0)
            {
                <text> y </text>
            }
            @if ((int)ViewBag.SessionCount > 0)
            {
                <strong>@ViewBag.SessionCount sesión(es)</strong>
            }
             asociado(s). Eliminá primero esos registros.
        </div>
    }
    <div class="kg-form-body">
        <div class="kg-detail-grid">
            <div class="kg-detail-item">
                <dt>Apellido y Nombre</dt>
                <dd>@Model.Apellido, @Model.Nombre</dd>
            </div>
            <div class="kg-detail-item">
                <dt>DNI</dt>
                <dd style="font-family:monospace">@Model.DNI</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Fecha de nacimiento</dt>
                <dd>@(Model.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "—")</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Obra social</dt>
                <dd>@(Model.ObraSocial ?? "—")</dd>
            </div>
        </div>
    </div>
    <div class="kg-form-footer">
        <a asp-action="Index" class="btn-kg-outline"><i class="bi bi-x-lg"></i> Cancelar</a>
        @if ((int)ViewBag.TreatmentCount == 0 && (int)ViewBag.SessionCount == 0)
        {
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-kg-danger">
                    <i class="bi bi-trash-fill"></i> Confirmar Baja
                </button>
            </form>
        }
    </div>
</div>

