@model KineGestion.Web.Models.ViewModels.PatientDetailsViewModel
@using KineGestion.Core

@{
    ViewData["Title"] = "Detalle del Paciente";
    var p = Model.Patient;
}

<div class="kg-page-header">
    <div>
        <h2>Detalle del Paciente</h2>
        <p class="text-muted mb-0">Información completa del paciente</p>
    </div>
    <a asp-action="Index" class="btn-kg-outline">
        <i class="bi bi-arrow-left"></i> Volver al listado
    </a>
</div>

<div class="kg-form-card">
    <div class="kg-form-header" style="justify-content:space-between">
        <div style="display:flex;align-items:center;gap:12px">
            <div style="width:48px;height:48px;border-radius:50%;background:#dbeafe;color:#2563eb;display:flex;align-items:center;justify-content:center;font-size:1.2rem;font-weight:700">
                @(p.Nombre.Length > 0 ? p.Nombre[0].ToString().ToUpper() : "?")@(p.Apellido.Length > 0 ? p.Apellido[0].ToString().ToUpper() : "")
            </div>
            <div>
                <h4 style="margin:0">@p.Apellido, @p.Nombre</h4>
                <p style="margin:0;font-size:.78rem;color:var(--kg-text-muted)">DNI @p.DNI</p>
            </div>
        </div>
        @if (p.IsActivo)
        {
            <span class="kg-badge kg-badge-success"><i class="bi bi-circle-fill" style="font-size:.45rem"></i> Activo</span>
        }
        else
        {
            <span class="kg-badge kg-badge-muted">Inactivo</span>
        }
    </div>
    <div class="kg-form-body">
        <div class="kg-detail-grid">
            <div class="kg-detail-item">
                <dt>Nombre completo</dt>
                <dd>@p.Apellido, @p.Nombre</dd>
            </div>
            <div class="kg-detail-item">
                <dt>DNI</dt>
                <dd style="font-family:monospace">@p.DNI</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Fecha de nacimiento</dt>
                <dd>@(p.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "—")</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Obra social</dt>
                <dd>@(p.ObraSocial ?? "—")</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Teléfono</dt>
                <dd>@(p.Telefono ?? "—")</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Email</dt>
                <dd>@(p.Email ?? "—")</dd>
            </div>
        </div>

        <div class="mt-4" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:1rem 1.25rem">
            <p style="margin:0 0 .75rem;font-weight:700;font-size:.82rem;color:#475569;text-transform:uppercase;letter-spacing:.05em">
                <i class="bi bi-clock-history me-1"></i>Trazabilidad
            </p>
            <div class="kg-detail-grid">
                <div class="kg-detail-item">
                    <dt>Creado por</dt>
                    <dd>@p.CreatedBy</dd>
                </div>
                <div class="kg-detail-item">
                    <dt>Creado el</dt>
                    <dd>@p.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                </div>
                <div class="kg-detail-item">
                    <dt>Última modificación por</dt>
                    <dd>@p.UpdatedBy</dd>
                </div>
                <div class="kg-detail-item">
                    <dt>Última modificación</dt>
                    <dd>@p.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                </div>
            </div>
        </div>
    </div>
    <div class="kg-form-footer">
        <a asp-action="Index" class="btn-kg-outline"><i class="bi bi-arrow-left"></i> Volver</a>
        <div style="display:flex;gap:10px">
            <a asp-controller="Sessions" asp-action="Create" asp-route-patientId="@p.Id" class="btn-kg-primary" style="background:#22c55e">
                <i class="bi bi-calendar2-plus-fill"></i> Nueva Sesión
            </a>
            <a asp-action="Edit" asp-route-id="@p.Id" class="btn-kg-warning">
                <i class="bi bi-pencil-fill"></i> Editar
            </a>
        </div>
    </div>
</div>

@* Tratamientos *@
<div class="kg-card" style="margin-top:20px">
    <div class="kg-card-header">
        <h5 class="kg-card-header-title">
            <i class="bi bi-clipboard2-pulse-fill"></i> Tratamientos
        </h5>
        <span class="kg-badge kg-badge-muted">@Model.Treatments.Count() tratamiento(s)</span>
    </div>

    @if (!Model.Treatments.Any())
    {
        <div class="kg-empty" style="padding:24px">
            <p style="color:var(--kg-text-muted);margin:0">Este paciente no tiene tratamientos registrados.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="kg-table">
                <thead>
                    <tr>
                        <th>Descripción</th>
                        <th>Inicio</th>
                        <th>Sesiones</th>
                        <th style="text-align:right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Treatments)
                    {
                        <tr>
                            <td><span style="font-weight:600">@t.Descripcion</span></td>
                            <td>@t.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="kg-badge kg-badge-info">@t.SesionesRealizadas / @t.CantidadSesionesTotales</span>
                            </td>
                            <td>
                                <div class="kg-action-btns" style="justify-content:flex-end">
                                    <a asp-controller="Treatments" asp-action="Details" asp-route-id="@t.Id" class="kg-action-btn view" title="Ver detalle"><i class="bi bi-eye-fill"></i></a>
                                    <a asp-controller="Treatments" asp-action="Edit" asp-route-id="@t.Id" class="kg-action-btn edit" title="Editar"><i class="bi bi-pencil-fill"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* Sesiones *@
<div class="kg-card" style="margin-top:20px">
    <div class="kg-card-header">
        <h5 class="kg-card-header-title">
            <i class="bi bi-calendar2-check-fill"></i> Últimas Sesiones
        </h5>
        <span class="kg-badge kg-badge-muted">@Model.Sessions.Count() sesión(es)</span>
    </div>

    @if (!Model.Sessions.Any())
    {
        <div class="kg-empty" style="padding:24px">
            <p style="color:var(--kg-text-muted);margin:0">Este paciente no tiene sesiones registradas.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="kg-table">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tratamiento</th>
                        <th>Profesional</th>
                        <th>Estado</th>
                        <th>Pago</th>
                        <th style="text-align:right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Sessions)
                    {
                        <tr>
                            <td style="white-space:nowrap">@s.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(s.TratamientoDescripcion ?? "—")</td>
                            <td>@(s.ProfesionalNombre ?? "—")</td>
                            <td>
                                @if (s.Status == SessionStatus.Completed)
                                {
                                    <span class="kg-badge kg-badge-success">Completada</span>
                                }
                                else if (s.Status == SessionStatus.Canceled)
                                {
                                    <span class="kg-badge kg-badge-danger">Cancelada</span>
                                }
                                else
                                {
                                    <span class="kg-badge kg-badge-warning">Pendiente</span>
                                }
                            </td>
                            <td>
                                @if (s.PaymentStatus == PaymentStatus.Paid)
                                {
                                    <span class="kg-badge kg-badge-success"><i class="bi bi-check-circle-fill"></i> Pagada</span>
                                }
                                else
                                {
                                    <span class="kg-badge kg-badge-muted">Pendiente</span>
                                }
                            </td>
                            <td>
                                <div class="kg-action-btns" style="justify-content:flex-end">
                                    <a asp-controller="Sessions" asp-action="Details" asp-route-id="@s.Id" class="kg-action-btn view" title="Ver detalle"><i class="bi bi-eye-fill"></i></a>
                                    <a asp-controller="Sessions" asp-action="Edit" asp-route-id="@s.Id" class="kg-action-btn edit" title="Editar"><i class="bi bi-pencil-fill"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
