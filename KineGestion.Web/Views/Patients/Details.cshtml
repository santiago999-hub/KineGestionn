@model KineGestion.Web.Models.ViewModels.PatientViewModel

@{
    ViewData["Title"] = "Detalle del Paciente";
}

<div class="kg-page-header">
    <div>
        <h2>Detalle del Paciente</h2>
        <p class="text-muted mb-0">Información completa del paciente</p>
    </div>
    <a asp-action="Index" class="btn-kg-outline">
        <i class="bi bi-arrow-left"></i> Volver al listado
    </a>
</div>

<div class="kg-form-card">
    <div class="kg-form-header" style="justify-content:space-between">
        <div style="display:flex;align-items:center;gap:12px">
            <div style="width:48px;height:48px;border-radius:50%;background:#dbeafe;color:#2563eb;display:flex;align-items:center;justify-content:center;font-size:1.2rem;font-weight:700">
                @(Model.Nombre.Length > 0 ? Model.Nombre[0].ToString().ToUpper() : "?")@(Model.Apellido.Length > 0 ? Model.Apellido[0].ToString().ToUpper() : "")
            </div>
            <div>
                <h4 style="margin:0">@Model.Apellido, @Model.Nombre</h4>
                <p style="margin:0;font-size:.78rem;color:var(--kg-text-muted)">DNI @Model.DNI</p>
            </div>
        </div>
        @if (Model.IsActivo)
        {
            <span class="kg-badge kg-badge-success"><i class="bi bi-circle-fill" style="font-size:.45rem"></i> Activo</span>
        }
        else
        {
            <span class="kg-badge kg-badge-muted">Inactivo</span>
        }
    </div>
    <div class="kg-form-body">
        <div class="kg-detail-grid">
            <div class="kg-detail-item">
                <dt>Nombre completo</dt>
                <dd>@Model.Apellido, @Model.Nombre</dd>
            </div>
            <div class="kg-detail-item">
                <dt>DNI</dt>
                <dd style="font-family:monospace">@Model.DNI</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Fecha de nacimiento</dt>
                <dd>@Model.FechaNacimiento.ToString("dd/MM/yyyy")</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Obra social</dt>
                <dd>@(Model.ObraSocial ?? "—")</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Teléfono</dt>
                <dd>@(Model.Telefono ?? "—")</dd>
            </div>
            <div class="kg-detail-item">
                <dt>Email</dt>
                <dd>@(Model.Email ?? "—")</dd>
            </div>
        </div>
    </div>
    <div class="kg-form-footer">
        <a asp-action="Index" class="btn-kg-outline"><i class="bi bi-arrow-left"></i> Volver</a>
        <div style="display:flex;gap:10px">
            <a asp-controller="Sessions" asp-action="Create" asp-route-patientId="@Model.Id" class="btn-kg-primary" style="background:#22c55e">
                <i class="bi bi-calendar2-plus-fill"></i> Nueva Sesión
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-kg-warning">
                <i class="bi bi-pencil-fill"></i> Editar
            </a>
        </div>
    </div>
</div>
