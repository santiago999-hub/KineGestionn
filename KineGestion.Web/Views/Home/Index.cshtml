@model KineGestion.Web.Models.ViewModels.HomeDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="kg-dashboard-hero mb-4">
    <div class="kg-dashboard-hero-copy">
        <div class="kg-dashboard-hero-kicker">
            <i class="bi bi-speedometer2"></i>
            Panel operativo
        </div>
        <h2>Tu centro de control para el día de trabajo</h2>
        <p>
            Acá tenés el estado general del sistema, los indicadores que importan y los accesos rápidos
            para resolver la operación clínica sin navegar de más.
        </p>
        <div class="kg-dashboard-hero-actions">
            <a asp-controller="Sessions" asp-action="Index" asp-route-dateFrom="@DateTime.Today.ToString("yyyy-MM-dd")" asp-route-dateTo="@DateTime.Today.ToString("yyyy-MM-dd")" class="btn-kg-primary">
                <i class="bi bi-calendar2-week-fill"></i>
                Ver agenda de hoy
            </a>
            <a asp-controller="Home" asp-action="QuienesSomos" class="btn-kg-outline">
                <i class="bi bi-info-circle"></i>
                Conocer la plataforma
            </a>
        </div>
    </div>

    <div class="kg-dashboard-hero-meta">
        <div class="kg-dashboard-hero-chip">
            <i class="bi bi-calendar3"></i>
            <span>@DateTime.Today.ToString("dd/MM/yyyy")</span>
        </div>
        <div class="kg-dashboard-hero-chip">
            <i class="bi bi-activity"></i>
            <span>Sesión protegida y auditada</span>
        </div>
        <div class="kg-dashboard-hero-chip">
            <i class="bi bi-shield-check"></i>
            <span>@User.Identity?.Name</span>
        </div>
    </div>
</div>

<!-- Page Header -->
<div class="kg-page-header">
    <div>
        <h2>Dashboard</h2>
        <p class="text-muted mb-0">Resumen operativo del centro de kinesiología</p>
    </div>
    <span class="kg-badge kg-badge-success">
        <i class="bi bi-circle-fill kg-badge-dot"></i> Sistema activo
    </span>
</div>

@if (Model.IsBillingOperationalAlertActive)
{
    <div class="alert alert-danger d-flex justify-content-between align-items-center mb-3" role="alert">
        <div>
            <strong>Alerta operativa activa:</strong>
            Se detectaron 2 semanas consecutivas con baja efectividad de cobranzas.
            @if (Model.IsBillingOperationalAlertSentToday)
            {
                <span class="ms-2">Notificación administrativa enviada hoy.</span>
            }
            @if (Model.LastBillingOperationalAlertAtUtc.HasValue)
            {
                <span class="ms-2">Último envío: @Model.LastBillingOperationalAlertAtUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.LastBillingOperationalAlertChangedBy))
            {
                <span class="ms-2">Disparado por: @Model.LastBillingOperationalAlertChangedBy</span>
            }
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Billing" asp-action="Index" class="btn btn-sm btn-outline-danger">Ir a Cobranzas</a>
            <a asp-controller="Reminders" asp-action="Index" class="btn btn-sm btn-outline-secondary">Ir a Recordatorios</a>
            @if (User.IsInRole("Admin"))
            {
                <form asp-controller="Home" asp-action="TriggerBillingOperationalAlert" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-danger">Reintentar alerta</button>
                </form>
            }
        </div>
    </div>

    @if (Model.RecentBillingOperationalAlerts.Any())
    {
        <div class="alert alert-light border mb-3" role="status">
            <strong>Últimas alertas operativas:</strong>
            <ul class="mb-0 mt-2">
                @foreach (var item in Model.RecentBillingOperationalAlerts)
                {
                    <li>@item.ChangedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm") - @item.ChangedBy</li>
                }
            </ul>
        </div>
    }
}

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="kg-stat-card">
            <div class="kg-stat-icon blue"><i class="bi bi-people-fill"></i></div>
            <div>
                <div class="kg-stat-label">Pacientes activos</div>
                <div class="kg-stat-value">@Model.PacientesActivosCount</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="kg-stat-card">
            <div class="kg-stat-icon cyan"><i class="bi bi-person-badge-fill"></i></div>
            <div>
                <div class="kg-stat-label">Profesionales</div>
                <div class="kg-stat-value">@Model.ProfesionalesActivosCount</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="kg-stat-card">
            <div class="kg-stat-icon green"><i class="bi bi-journal-medical"></i></div>
            <div>
                <div class="kg-stat-label">Tratamientos</div>
                <div class="kg-stat-value">@Model.TratamientosCount</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="kg-stat-card">
            <div class="kg-stat-icon violet"><i class="bi bi-calendar2-check-fill"></i></div>
            <div>
                <div class="kg-stat-label">Sesiones</div>
                <div class="kg-stat-value">@Model.SesionesCount</div>
            </div>
        </div>
    </div>
</div>

<!-- Operational Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Sessions" asp-action="Index" asp-route-dateFrom="@DateTime.Today.ToString("yyyy-MM-dd")" asp-route-dateTo="@DateTime.Today.ToString("yyyy-MM-dd")" class="kg-stat-card kg-stat-link">
            <div class="kg-stat-icon orange"><i class="bi bi-calendar2-day-fill"></i></div>
            <div>
                <div class="kg-stat-label">Sesiones hoy</div>
                <div class="kg-stat-value">@Model.SesionesHoyCount</div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Sessions" asp-action="Index" asp-route-status="Completed" asp-route-dateFrom="@DateTime.Today.ToString("yyyy-MM-dd")" asp-route-dateTo="@DateTime.Today.ToString("yyyy-MM-dd")" class="kg-stat-card kg-stat-link">
            <div class="kg-stat-icon green"><i class="bi bi-check2-circle"></i></div>
            <div>
                <div class="kg-stat-label">Completadas hoy</div>
                <div class="kg-stat-value">@Model.SesionesCompletadasHoyCount</div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Billing" asp-action="Index" asp-route-onlyCompletedPending="true" class="kg-stat-card kg-stat-link">
            <div class="kg-stat-icon red"><i class="bi bi-credit-card-fill"></i></div>
            <div>
                <div class="kg-stat-label">Completadas sin cobrar</div>
                <div class="kg-stat-value">@Model.SesionesPendientesPagoCount</div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Sessions" asp-action="Index" asp-route-status="Pending" class="kg-stat-card kg-stat-link">
            <div class="kg-stat-icon yellow"><i class="bi bi-hourglass-split"></i></div>
            <div>
                <div class="kg-stat-label">Sin confirmar</div>
                <div class="kg-stat-value">@Model.SesionesPendientesConfirmacionCount</div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Sessions" asp-action="Index" asp-route-status="Canceled" asp-route-dateFrom="@DateTime.Today.ToString("yyyy-MM-dd")" asp-route-dateTo="@DateTime.Today.ToString("yyyy-MM-dd")" class="kg-stat-card kg-stat-link">
            <div class="kg-stat-icon orange"><i class="bi bi-x-circle-fill"></i></div>
            <div>
                <div class="kg-stat-label">Canceladas hoy</div>
                <div class="kg-stat-value">@Model.SesionesCanceladasHoyCount</div>
            </div>
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-4">
        <div class="kg-stat-card">
            <div class="kg-stat-icon green"><i class="bi bi-graph-up-arrow"></i></div>
            <div>
                <div class="kg-stat-label">Cumplimiento hoy</div>
                <div class="kg-stat-value">@Model.CompletionRateToday.ToString("N2")%</div>
                <small class="text-muted">Completadas sobre sesiones del día</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="kg-stat-card">
            <div class="kg-stat-icon cyan"><i class="bi bi-cash-stack"></i></div>
            <div>
                <div class="kg-stat-label">Tasa de cobranza (30d)</div>
                <div class="kg-stat-value">@Model.CollectionRateLast30Days.ToString("N2")%</div>
                <small class="text-muted">Sesiones pagadas sobre total de sesiones</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="kg-stat-card">
            <div class="kg-stat-icon orange"><i class="bi bi-exclamation-circle"></i></div>
            <div>
                <div class="kg-stat-label">Tasa de cancelación (30d)</div>
                <div class="kg-stat-value">@Model.CancellationRateLast30Days.ToString("N2")%</div>
                <small class="text-muted">Canceladas sobre total de sesiones</small>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions + Info -->
<div class="row g-3">
    <div class="col-lg-7">
        <div class="kg-card">
            <div class="kg-card-header">
                <h5 class="kg-card-header-title">
                    <i class="bi bi-lightning-charge-fill"></i> Acciones rápidas
                </h5>
            </div>
            <div class="kg-card-body">
                <div class="kg-action-priority-label">Prioridad de hoy</div>
                <div class="kg-action-priority-strip mb-4">
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Sessions" asp-action="Index" asp-route-paymentStatus="Pending" asp-route-dateFrom="@DateTime.Today.ToString("yyyy-MM-dd")" asp-route-dateTo="@DateTime.Today.ToString("yyyy-MM-dd")" class="kg-quick-action kg-quick-action-featured">
                            <i class="bi bi-cash-stack"></i>
                            <div>
                                <span class="kg-quick-action-kicker">Urgente</span>
                                <div>Pagos Pendientes de Hoy</div>
                                <div class="kg-quick-action-help">Filtrar cobros pendientes del día</div>
                            </div>
                        </a>
                        <a asp-controller="Sessions" asp-action="Index" asp-route-status="Pending" asp-route-dateFrom="@DateTime.Today.ToString("yyyy-MM-dd")" asp-route-dateTo="@DateTime.Today.ToString("yyyy-MM-dd")" class="kg-quick-action kg-quick-action-featured">
                            <i class="bi bi-hourglass-split"></i>
                            <div>
                                <span class="kg-quick-action-kicker">Control</span>
                                <div>Sin Confirmar de Hoy</div>
                                <div class="kg-quick-action-help">Revisar sesiones pendientes del día</div>
                            </div>
                        </a>
                        <a asp-controller="Sessions" asp-action="Index" asp-route-status="Canceled" asp-route-dateFrom="@DateTime.Today.ToString("yyyy-MM-dd")" asp-route-dateTo="@DateTime.Today.ToString("yyyy-MM-dd")" class="kg-quick-action kg-quick-action-featured">
                            <i class="bi bi-arrow-repeat"></i>
                            <div>
                                <span class="kg-quick-action-kicker">Seguimiento</span>
                                <div>Canceladas de Hoy</div>
                                <div class="kg-quick-action-help">Priorizar recupero y reprogramación</div>
                            </div>
                        </a>
                        <a asp-controller="Sessions" asp-action="Create" class="kg-quick-action kg-quick-action-featured">
                            <i class="bi bi-calendar2-plus-fill"></i>
                            <div>
                                <span class="kg-quick-action-kicker">Nuevo</span>
                                <div>Nueva Sesión</div>
                                <div class="kg-quick-action-help">Registrar sesión clínica</div>
                            </div>
                        </a>
                    }
                    else if (User.IsInRole("Kinesiologo"))
                    {
                        <a asp-controller="Sessions" asp-action="MyAgenda" asp-route-dateFrom="@DateTime.Today.ToString("yyyy-MM-dd")" asp-route-dateTo="@DateTime.Today.ToString("yyyy-MM-dd")" class="kg-quick-action kg-quick-action-featured">
                            <i class="bi bi-calendar2-week-fill"></i>
                            <div>
                                <span class="kg-quick-action-kicker">Hoy</span>
                                <div>Mi Agenda de Hoy</div>
                                <div class="kg-quick-action-help">Ver solo tus turnos de hoy</div>
                            </div>
                        </a>
                        <a asp-controller="Sessions" asp-action="Create" class="kg-quick-action kg-quick-action-featured">
                            <i class="bi bi-calendar2-plus-fill"></i>
                            <div>
                                <span class="kg-quick-action-kicker">Nuevo</span>
                                <div>Nueva Sesión</div>
                                <div class="kg-quick-action-help">Registrar sesión clínica</div>
                            </div>
                        </a>
                    }
                </div>

                <div class="row g-3">
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="col-sm-6">
                            <a asp-controller="Patients" asp-action="Create" class="kg-quick-action">
                                <i class="bi bi-person-plus-fill"></i>
                                <div>
                                    <div>Nuevo Paciente</div>
                                    <div class="kg-quick-action-help">Registrar en el sistema</div>
                                </div>
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <a asp-controller="Treatments" asp-action="Create" class="kg-quick-action">
                                <i class="bi bi-journal-plus"></i>
                                <div>
                                    <div>Nuevo Tratamiento</div>
                                    <div class="kg-quick-action-help">Asignar a un paciente</div>
                                </div>
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <a asp-controller="Professionals" asp-action="Create" class="kg-quick-action">
                                <i class="bi bi-person-badge-fill"></i>
                                <div>
                                    <div>Nuevo Profesional</div>
                                    <div class="kg-quick-action-help">Dar de alta kinesiólogo</div>
                                </div>
                            </a>
                        </div>
                    }
                    else if (User.IsInRole("Kinesiologo"))
                    {
                        <div class="col-12">
                            <div class="kg-empty kg-quick-action-empty">
                                <div class="kg-empty-icon"><i class="bi bi-clipboard2-check"></i></div>
                                <h5>Accesos operativos listos</h5>
                                <p>Usá la prioridad de hoy para abrir la agenda o registrar una nueva sesión sin pasos extra.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="kg-card h-100">
            <div class="kg-card-header">
                <h5 class="kg-card-header-title">
                    <i class="bi bi-info-circle-fill"></i> Información del sistema
                </h5>
            </div>
            <div class="kg-card-body">
                <ul class="list-unstyled mb-0 kg-system-list">
                    <li class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Versión</span>
                        <span class="kg-badge kg-badge-primary">v1.0 — Sprint 2</span>
                    </li>
                    <li class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Base de datos</span>
                        <span class="kg-badge kg-badge-success"><i class="bi bi-circle-fill kg-badge-dot-sm"></i> SQL Server</span>
                    </li>
                    <li class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Framework</span>
                        <span class="kg-badge kg-badge-info">.NET 8 MVC</span>
                    </li>
                    <li class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Arquitectura</span>
                        <span class="kg-badge kg-badge-violet">Clean Architecture</span>
                    </li>
                    <li class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Fecha</span>
                        <span class="kg-system-date">@DateTime.Today.ToString("dd/MM/yyyy")</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
