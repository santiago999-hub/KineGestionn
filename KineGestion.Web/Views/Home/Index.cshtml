@model KineGestion.Web.Models.ViewModels.HomeDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
    <h1 class="display-6 fw-bold text-primary">Dashboard Operativo</h1>
    <p class="text-muted mb-0">Resumen rapido del estado actual del centro.</p>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="text-muted mb-1">Pacientes Activos</h5>
                    <p class="display-5 fw-bold mb-0 text-success">@Model.PacientesActivosCount</p>
                </div>
                <div class="fs-1">👥</div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="text-muted mb-1">Profesionales Activos</h5>
                    <p class="display-5 fw-bold mb-0 text-info">@Model.ProfesionalesActivosCount</p>
                </div>
                <div class="fs-1">🩺</div>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4 shadow-sm border-0">
    <div class="card-body">
        <h5 class="card-title">Acciones rapidas</h5>
        <div class="d-flex flex-wrap gap-2 mt-3">
            <a asp-controller="Patients" asp-action="Create" class="btn btn-outline-primary">Nuevo Paciente</a>
            <a asp-controller="Professionals" asp-action="Create" class="btn btn-outline-secondary">Nuevo Profesional</a>
            <a asp-controller="Sessions" asp-action="Create" class="btn btn-outline-success">Nueva Sesion</a>
        </div>
    </div>
</div>
